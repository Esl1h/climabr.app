---
import PainelLayout from '../../layouts/PainelLayout.astro';
import BlocoPrevisao from '../../components/BlocoPrevisao.astro';
import BlocoReservatorio from '../../components/BlocoReservatorio.astro';
import BlocoQueimadas from '../../components/BlocoQueimadas.astro';
import BlocoAr from '../../components/BlocoAr.astro';
import BlocoUV from '../../components/BlocoUV.astro';
import BlocoDengue from '../../components/BlocoDengue.astro';
import BlocoSol from '../../components/BlocoSol.astro';
import BlocoVento from '../../components/BlocoVento.astro';
import BlocoOndas from '../../components/BlocoOndas.astro';
import municipiosRaw from '../../../data/municipios.json';
import type { Municipio, DadosCidade } from '../../lib/types';

export async function getStaticPaths() {
  const municipios = municipiosRaw as Municipio[];
  return municipios.map((m) => ({
    params: { estado: m.estado, cidade: m.slug },
    props: { municipio: m },
  }));
}

interface Props {
  municipio: Municipio;
}

const { municipio } = Astro.props;
const { estado, cidade } = Astro.params;

let dados: DadosCidade | null = null;

try {
  const fs = await import('node:fs/promises');
  const path = await import('node:path');
  const filePath = path.join(process.cwd(), 'data', 'cidades', estado, `${cidade}.json`);
  const raw = await fs.readFile(filePath, 'utf-8');
  dados = JSON.parse(raw) as DadosCidade;
} catch {
  // Dados ainda não coletados
}

// Monta description dinâmica com os dados disponíveis
function montarDescricao(): string {
  if (!dados) return `Painel ambiental de ${municipio.nome}, ${municipio.estado_nome}.`;
  const partes: string[] = [];
  if (dados.qualidade_ar?.categoria) partes.push(`Ar: ${dados.qualidade_ar.categoria}`);
  if (dados.reservatorio?.nivel_pct != null) partes.push(`Reservatório: ${dados.reservatorio.nivel_pct}%`);
  if (dados.dengue?.nivel_label) partes.push(`Dengue: ${dados.dengue.nivel_label}`);
  if (dados.queimadas?.focos_100km != null) partes.push(`Queimadas: ${dados.queimadas.focos_100km} focos`);
  const base = `Painel ambiental de ${municipio.nome}/${municipio.estado.toUpperCase()}`;
  return partes.length ? `${base} — ${partes.join(', ')}.` : `${base}.`;
}

const titulo = `${municipio.nome}/${municipio.estado.toUpperCase()} — climabr.app`;
const descricao = montarDescricao();

function formatarDataHora(iso: string): string {
  return new Date(iso).toLocaleString('pt-BR', {
    day: '2-digit', month: '2-digit', year: 'numeric',
    hour: '2-digit', minute: '2-digit',
    timeZone: 'America/Sao_Paulo',
  });
}

const temDados = dados && (
  dados.previsao?.length ||
  dados.qualidade_ar ||
  dados.uv ||
  dados.reservatorio ||
  dados.dengue ||
  dados.queimadas ||
  dados.sol
);
---

<PainelLayout
  title={titulo}
  description={descricao}
  cidade={municipio.nome}
  estado={municipio.estado}
>
  <nav class="mb-6 text-sm text-slate-500" aria-label="Navegação">
    <a href="/" class="hover:text-slate-300">climabr.app</a>
    <span class="mx-2">/</span>
    <span class="text-slate-300">{municipio.estado.toUpperCase()}</span>
    <span class="mx-2">/</span>
    <span class="text-white">{municipio.nome}</span>
  </nav>

  <div class="mb-8">
    <h1 class="text-2xl font-bold text-white">
      {municipio.nome}
      <span class="text-slate-400 text-lg">/{municipio.estado.toUpperCase()}</span>
    </h1>
    {dados?.temperatura_atual != null && (
      <p class="mt-1 text-slate-300 text-sm">{dados.temperatura_atual}°C agora</p>
    )}
    {dados?.atualizado_em ? (
      <p class="mt-1 text-xs text-slate-500">
        Atualizado em {formatarDataHora(dados.atualizado_em)}
      </p>
    ) : (
      <p class="mt-1 text-xs text-slate-500">Dados ainda não coletados para esta cidade.</p>
    )}
  </div>

  {temDados ? (
    <div class="space-y-8">
      <BlocoPrevisao previsao={dados!.previsao} />
      <BlocoAr qualidade_ar={dados!.qualidade_ar} />
      <BlocoUV uv={dados!.uv} />
      <BlocoReservatorio reservatorio={dados!.reservatorio} />
      <BlocoVento vento={dados!.vento} />
      <BlocoOndas ondas={dados!.ondas} />
      <BlocoQueimadas queimadas={dados!.queimadas} />
      <BlocoDengue
        dengue={dados!.dengue}
        chikungunya={dados!.chikungunya}
        zika={dados!.zika}
      />
      <BlocoSol sol={dados!.sol} lua={dados!.lua} />
    </div>
  ) : (
    <div class="rounded-lg border border-slate-800 bg-slate-900 p-8 text-center">
      <p class="text-slate-400">
        Os dados de <strong class="text-white">{municipio.nome}</strong> ainda estão sendo coletados.
      </p>
      <p class="mt-2 text-sm text-slate-500">
        As coletas acontecem automaticamente a cada 3-6 horas via GitHub Actions.
      </p>
      <div class="mt-4 flex justify-center gap-4 text-sm">
        <a href={`/api/${estado}/${cidade}.json`} class="text-emerald-400 hover:underline">
          Ver JSON
        </a>
        <a href="/" class="text-slate-400 hover:text-slate-200 hover:underline">
          Voltar ao início
        </a>
      </div>
    </div>
  )}

  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Dataset",
    "name": `Dados Ambientais — ${municipio.nome}/${municipio.estado.toUpperCase()}`,
    "description": descricao,
    "spatialCoverage": {
      "@type": "Place",
      "name": municipio.nome,
      "addressRegion": municipio.estado.toUpperCase(),
      "addressCountry": "BR"
    },
    "temporalCoverage": "2025/..",
    "url": `https://climabr.app/${estado}/${cidade}`,
    "license": "https://creativecommons.org/licenses/by/4.0/",
  })} />
</PainelLayout>
