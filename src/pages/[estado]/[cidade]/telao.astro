---
import '../../../styles/global.css';
import municipiosRaw from '../../../../data/municipios.json';
import type { Municipio, DadosCidade } from '../../../lib/types';

export async function getStaticPaths() {
  const municipios = municipiosRaw as Municipio[];
  return municipios.map((m) => ({
    params: { estado: m.estado, cidade: m.slug },
    props: { municipio: m },
  }));
}

interface Props {
  municipio: Municipio;
}

const { municipio } = Astro.props;
const { estado, cidade } = Astro.params;

let dados: DadosCidade | null = null;
try {
  const fs = await import('node:fs/promises');
  const path = await import('node:path');
  const filePath = path.join(process.cwd(), 'data', 'cidades', estado!, `${cidade}.json`);
  dados = JSON.parse(await fs.readFile(filePath, 'utf-8')) as DadosCidade;
} catch {
  // sem dados
}

const TEMPO_EMOJI: Record<number, string> = {
  0: '☀️', 1: '🌤', 2: '⛅', 3: '☁️', 45: '🌫', 48: '🌫',
  51: '🌦', 53: '🌦', 55: '🌧', 61: '🌧', 63: '🌧', 65: '🌧',
  71: '❄️', 73: '❄️', 75: '❄️', 77: '🌨', 80: '🌦', 81: '🌦',
  82: '⛈', 95: '⛈', 96: '⛈', 99: '⛈',
};
const LUA_EMOJI: Record<string, string> = {
  'Nova': '🌑', 'Crescente': '🌒', 'Quarto Crescente': '🌓', 'Gibosa Crescente': '🌔',
  'Cheia': '🌕', 'Gibosa Minguante': '🌖', 'Quarto Minguante': '🌗', 'Minguante': '🌘',
};

function corAqi(i: number) { return i <= 50 ? '#34d399' : i <= 100 ? '#fbbf24' : i <= 150 ? '#fb923c' : '#f87171'; }
function corUv(i: number) { return i < 3 ? '#34d399' : i < 6 ? '#fbbf24' : i < 8 ? '#fb923c' : i < 11 ? '#f87171' : '#a78bfa'; }
function corNivel(p: number) { return p >= 70 ? '#34d399' : p >= 40 ? '#fbbf24' : '#f87171'; }
function corVento(v: number) { return v < 20 ? '#34d399' : v < 40 ? '#fbbf24' : v < 60 ? '#fb923c' : '#f87171'; }
function corDengue(n: number) { return ['#34d399','#fbbf24','#fb923c','#f87171','#ef4444'][n] ?? '#94a3b8'; }
function corFocos(f: number) { return f === 0 ? '#34d399' : f <= 5 ? '#fbbf24' : f <= 20 ? '#fb923c' : '#f87171'; }

const previsao = dados?.previsao ?? [];
const hoje = previsao[0];
const ar = dados?.qualidade_ar;
const uv = dados?.uv;
const vento = dados?.vento;
const ondas = dados?.ondas;
const res = dados?.reservatorio;
const q = dados?.queimadas;
const dengue = dados?.dengue;
const sol = dados?.sol;
const lua = dados?.lua;

// Condições atuais do ar (umidade, pressão, ponto de orvalho) — vão no card de Ar
const condParts: string[] = [];
if (dados?.umidade_pct != null) condParts.push(`💧${dados.umidade_pct}%`);
if (dados?.pressao_hpa != null) condParts.push(`${dados.pressao_hpa}hPa`);
if (dados?.ponto_orvalho_c != null) condParts.push(`🌡${Math.round(dados.ponto_orvalho_c)}°`);
const arCond = condParts.length ? ' · ' + condParts.join(' · ') : '';

const SURF_COR: Record<string, string> = {
  bom: '#34d399', razoavel: '#fbbf24', ruim: '#f87171', perigoso: '#ef4444', desconhecido: '#94a3b8',
};

// Tema do plano de fundo conforme a condição do tempo (WMO weather code)
function temaDoTempo(code?: number | string | null): string {
  const c = Number(code);
  if (!Number.isFinite(c)) return 'clima-limpo';
  if (c <= 1) return 'clima-limpo';
  if (c === 2) return 'clima-nublado';
  if (c === 3 || c === 45 || c === 48) return 'clima-encoberto';
  if ((c >= 51 && c <= 67) || (c >= 80 && c <= 82)) return 'clima-chuva';
  if ((c >= 71 && c <= 77) || c === 85 || c === 86) return 'clima-neve';
  if (c >= 95) return 'clima-tempestade';
  return 'clima-limpo';
}
const tema = temaDoTempo(hoje?.condicao_codigo);
const nascer = sol?.nascer ?? '';
const por = sol?.por ?? '';

// Ícone da estação do ano (exibida no cabeçalho, ao lado da condição)
function iconeEstacao(e: string): string {
  const n = e.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
  if (n.includes('verao')) return '🌻';
  if (n.includes('outono')) return '🍂';
  if (n.includes('inverno')) return '❄️';
  if (n.includes('primavera')) return '🌸';
  return '📅';
}
const estacao = sol?.estacao ?? '';
const estacaoIcone = estacao ? iconeEstacao(estacao) : '';

// Emoji grande do tempo, usado como marca d'água do fundo
const climaEmoji = hoje ? (TEMPO_EMOJI[hoje.condicao_codigo as number] ?? '⛅') : '⛅';

const titulo = `${municipio.nome}/${municipio.estado.toUpperCase()} — Modo Painel — climabr.app`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{titulo}</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root { --gap: clamp(0.6rem, 1.4vmin, 1.6rem); }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; height: 100%; background: #020617; }
      body {
        font-family: system-ui, -apple-system, sans-serif;
        color: #f1f5f9;
        overflow: hidden;
      }

      /* Plano de fundo dinâmico conforme o clima */
      .cena {
        position: fixed; inset: 0; z-index: 0;
        background: linear-gradient(160deg, #0f172a, #1e293b);
        transition: background 1.5s ease, filter 1.5s ease;
      }
      .cena::before {
        content: ''; position: absolute; inset: -25%;
        background: radial-gradient(circle, var(--glow, rgba(255,255,255,0.06)), transparent 60%);
        animation: flutua 22s ease-in-out infinite alternate;
      }
      @keyframes flutua {
        from { transform: translate(-6%, -4%) scale(1); }
        to   { transform: translate(6%, 5%) scale(1.15); }
      }
      /* Marca d'água: ícone grande do tempo atual, deixa o clima óbvio no fundo */
      .cena-icone {
        position: fixed; z-index: 0;
        right: 3vmin; bottom: 0;
        font-size: clamp(9rem, 46vmin, 48rem);
        line-height: 1;
        opacity: 0.14;
        pointer-events: none; user-select: none;
        filter: drop-shadow(0 0 40px rgba(0,0,0,0.35));
        animation: respira 9s ease-in-out infinite alternate;
      }
      @keyframes respira { from { transform: scale(1); } to { transform: scale(1.06); } }
      .clima-limpo .cena      { --glow: rgba(250,204,21,0.28); background: radial-gradient(circle at 78% 18%, rgba(250,204,21,0.30), transparent 42%), linear-gradient(160deg, #075985, #0c4a6e 55%, #0e7490); }
      .clima-nublado .cena    { --glow: rgba(148,163,184,0.20); background: linear-gradient(160deg, #1e293b, #334155 60%, #475569); }
      .clima-encoberto .cena  { --glow: rgba(148,163,184,0.16); background: linear-gradient(160deg, #1f2937, #374151 60%, #4b5563); }
      .clima-chuva .cena      { --glow: rgba(59,130,246,0.20); background: radial-gradient(circle at 50% -10%, rgba(59,130,246,0.22), transparent 50%), linear-gradient(160deg, #0f172a, #1e3a5f 60%, #1e293b); }
      .clima-neve .cena       { --glow: rgba(226,232,240,0.25); background: linear-gradient(160deg, #334155, #475569 55%, #64748b); }
      .clima-tempestade .cena { --glow: rgba(167,139,250,0.28); background: radial-gradient(circle at 30% 8%, rgba(167,139,250,0.28), transparent 45%), linear-gradient(160deg, #0f0a1f, #1e1b4b 55%, #312e81); }

      /* Variante noturna (definida via JS conforme nascer/pôr do sol) */
      .noite .cena { filter: brightness(0.6) saturate(0.85); }
      .noite.clima-limpo .cena {
        --glow: rgba(148,163,184,0.18); filter: none;
        background: radial-gradient(circle at 80% 15%, rgba(148,163,184,0.16), transparent 40%), linear-gradient(160deg, #020617, #0f172a 60%, #1e1b4b);
      }

      /* Chuva animada para chuva/tempestade */
      .clima-chuva .cena::after, .clima-tempestade .cena::after {
        content: ''; position: absolute; inset: 0; pointer-events: none;
        background-image: repeating-linear-gradient(102deg, transparent 0 16px, rgba(186,210,255,0.10) 16px 17px);
        animation: chuva 0.8s linear infinite;
      }
      @keyframes chuva { to { background-position: -36px 130px; } }

      .telao {
        position: relative; z-index: 1;
        height: 100dvh;
        display: flex;
        flex-direction: column;
        padding: var(--gap);
        gap: var(--gap);
      }
      .topo {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: calc(var(--gap) * 0.4);
        border-bottom: 1px solid rgba(148,163,184,0.22);
        padding-bottom: var(--gap);
        text-shadow: 0 2px 16px rgba(0,0,0,0.45);
      }
      .topo-linha {
        display: flex;
        align-items: baseline;
        justify-content: center;
        flex-wrap: wrap;
        gap: var(--gap);
      }
      .cidade-nome { font-size: clamp(2.8rem, 7.2vmin, 8.5rem); font-weight: 800; line-height: 1; letter-spacing: -0.01em; }
      .cidade-uf { color: #cbd5e1; font-weight: 400; font-size: 0.5em; opacity: 0.7; }
      .temp-atual { font-size: clamp(2.6rem, 6.8vmin, 8rem); font-weight: 800; color: #7dd3fc; line-height: 1; }
      .relogio { font-size: clamp(1.6rem, 3.6vmin, 4rem); font-weight: 700; color: #f1f5f9; font-variant-numeric: tabular-nums; }
      .data-hoje { font-size: clamp(1rem, 2.1vmin, 2.2rem); color: #cbd5e1; }
      .clima-linha {
        display: flex; justify-content: center; align-items: center;
        gap: 0.5em; flex-wrap: wrap; color: #e2e8f0; font-weight: 600;
      }
      .clima-linha .estacao { display: inline-flex; align-items: center; gap: 0.35em; opacity: 0.92; }
      .clima-linha .sep { opacity: 0.35; margin-right: 0.35em; font-weight: 400; }

      .grid {
        flex: 1;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(clamp(240px, 28vmin, 540px), 1fr));
        grid-auto-rows: minmax(0, 1fr);
        gap: var(--gap);
        min-height: 0;
        align-content: stretch;
      }
      .card {
        position: relative;
        background: rgba(15, 23, 42, 0.55);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(148, 163, 184, 0.16);
        border-radius: clamp(0.75rem, 1.6vmin, 1.8rem);
        box-shadow: 0 10px 34px rgba(0, 0, 0, 0.35);
        padding: clamp(0.9rem, 2vmin, 2.2rem);
        display: flex;
        flex-direction: column;
        justify-content: center;       /* agrupa o conteúdo no centro vertical */
        gap: clamp(0.25rem, 0.7vmin, 0.8rem);
        overflow: hidden;
        min-height: 0;
      }
      .card-wide { grid-column: span 2; grid-row: span 2; }
      .card-wide .card-titulo { font-size: clamp(0.85rem, 1.9vmin, 2rem); }
      .card-wide .card-valor { font-size: clamp(2.4rem, 6vmin, 7rem); }
      .card-wide .prev-dia .d { font-size: clamp(0.8rem, 1.7vmin, 1.8rem); }
      .card-wide .prev-dia .e { font-size: clamp(1.6rem, 3.6vmin, 4rem); }
      .card-wide .prev-dia .t { font-size: clamp(1rem, 2.1vmin, 2.3rem); }
      .card-titulo {
        font-size: clamp(0.75rem, 1.6vmin, 1.7rem);
        color: #cbd5e1;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        display: flex; align-items: center; gap: 0.4em;
      }
      .card-valor { font-size: clamp(1.9rem, 4.8vmin, 5.5rem); font-weight: 800; line-height: 1; }
      .card-sub { font-size: clamp(0.8rem, 1.6vmin, 1.7rem); color: #94a3b8; }
      .card-ico { font-size: clamp(1.2rem, 2.5vmin, 2.8rem); }

      /* Centraliza o conteúdo dos cards, exceto o de previsão (card-wide).
         Mantém align-items: stretch para as barras de progresso ocuparem a largura. */
      .card:not(.card-wide) { text-align: center; }
      .card:not(.card-wide) .card-titulo { justify-content: center; }
      .card:not(.card-wide) .duo { justify-content: center; }

      .prev-dias { display: flex; gap: clamp(0.3rem, 0.8vmin, 1rem); justify-content: space-between; }
      .prev-dia { text-align: center; flex: 1; }
      .prev-dia .d { font-size: clamp(0.75rem, 1.6vmin, 1.7rem); color: #94a3b8; text-transform: capitalize; }
      .prev-dia .e { font-size: clamp(1.5rem, 3.4vmin, 3.6rem); }
      .prev-dia .t { font-size: clamp(0.9rem, 1.9vmin, 2.1rem); font-weight: 700; }

      .barra { height: clamp(0.4rem, 1vmin, 1rem); background: rgba(148,163,184,0.25); border-radius: 99px; overflow: hidden; }
      .barra > div { height: 100%; border-radius: 99px; }

      .canto {
        position: fixed; top: var(--gap);
        z-index: 10; opacity: 0.25; transition: opacity 0.2s;
        display: flex; gap: 0.5rem;
      }
      .canto.dir { right: var(--gap); }
      .canto.esq { left: var(--gap); }
      .canto:hover { opacity: 1; }
      .canto button, .canto a {
        background: rgba(30,41,59,0.7); color: #e2e8f0; border: 1px solid rgba(148,163,184,0.3);
        backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
        border-radius: 0.6rem; padding: 0.45rem 0.75rem; font-size: 0.95rem;
        cursor: pointer; text-decoration: none; font-family: inherit;
      }
      .canto button:hover, .canto a:hover { background: rgba(51,65,85,0.9); }

      .duo { display: flex; gap: 1em; align-items: baseline; }
      .duo .lbl { font-size: clamp(0.75rem, 1.5vmin, 1.6rem); color: #94a3b8; }

      @media (prefers-reduced-motion: reduce) {
        .cena::before, .cena::after, .cena-icone { animation: none; }
      }
    </style>
  </head>
  <body class={tema} data-lat={municipio.lat ?? ''} data-lon={municipio.lon ?? ''} data-nascer={nascer} data-por={por}>
    <div class="cena"></div>
    <div class="cena-icone" id="cena-icone">{climaEmoji}</div>

    <div class="canto esq">
      <button id="fs-btn" title="Tela cheia">⛶ Tela cheia</button>
    </div>
    <div class="canto dir">
      <a href={`/${estado}/${cidade}`} title="Sair">✕</a>
    </div>

    <div class="telao">
      <!-- Cabeçalho centralizado -->
      <div class="topo">
        <div class="topo-linha">
          <div class="temp-atual" id="temp-atual" hidden={dados?.temperatura_atual == null}>
            {dados?.temperatura_atual != null ? `${dados.temperatura_atual}°` : ''}
          </div>
          <div class="cidade-nome">
            {municipio.nome}<span class="cidade-uf">/{municipio.estado.toUpperCase()}</span>
          </div>
        </div>
        <div class="clima-linha" style="font-size: clamp(1.1rem, 2.3vmin, 2.5rem);" hidden={!hoje && !estacao}>
          <span id="condicao">{hoje ? `${TEMPO_EMOJI[hoje.condicao_codigo as number] ?? '⛅'} ${hoje.condicao}` : ''}</span>
          {estacao && (
            <span class="estacao">
              {hoje && <span class="sep">|</span>}
              {estacaoIcone} {estacao}
            </span>
          )}
        </div>
        <div class="topo-linha">
          <span class="relogio" id="relogio">--:--:--</span>
          <span class="data-hoje" id="data-hoje"></span>
          <span class="data-hoje">
            <span style="color:#10b981; font-weight:700;">Clima<span style="color:#3b82f6;">BR</span><span style="color:#eab308;">.app</span></span>
          </span>
        </div>
      </div>

      <!-- Grid de cards -->
      <div class="grid">
        <!-- Previsão (largo) -->
        {previsao.length > 0 && (
          <div class="card card-wide">
            <div class="card-titulo"><span class="card-ico">⛅</span> Previsão</div>
            {hoje && (
              <div class="duo">
                <span class="card-valor" style="color:#f87171;" data-f="max">{Math.round(hoje.max)}°</span>
                <span class="card-valor" style="color:#38bdf8; font-size:clamp(1.3rem,3.2vmin,3.6rem);" data-f="min">{Math.round(hoje.min)}°</span>
                <span class="card-sub" data-f="chuva" hidden={!(hoje.chuva_mm > 0)}>{hoje.chuva_mm > 0 ? `💧${hoje.chuva_mm}mm` : ''}</span>
              </div>
            )}
            <div class="prev-dias" data-prev-dias>
              {previsao.slice(1, 7).map((d) => {
                const data = new Date((d.data as string) + 'T12:00:00');
                const dia = data.toLocaleDateString('pt-BR', { weekday: 'short' }).slice(0, 3);
                return (
                  <div class="prev-dia" data-dia>
                    <div class="d" data-f="d">{dia}</div>
                    <div class="e" data-f="e">{TEMPO_EMOJI[d.condicao_codigo as number] ?? '⛅'}</div>
                    <div class="t" style="color:#f87171;" data-f="tmax">{Math.round(d.max)}°</div>
                    <div class="t" style="color:#64748b;" data-f="tmin">{Math.round(d.min)}°</div>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        <!-- Qualidade do ar -->
        {ar && (
          <div class="card">
            <div class="card-titulo"><span class="card-ico">💨</span> Ar</div>
            <div class="card-valor" style={`color:${corAqi(ar.indice)}`}>{ar.indice}</div>
            <div class="card-sub">{ar.categoria}<span id="ar-cond">{arCond}</span></div>
            <div class="barra"><div style={`width:${Math.min(100, ar.indice / 3)}%; background:${corAqi(ar.indice)}`}></div></div>
          </div>
        )}

        <!-- UV -->
        {uv && uv.indice > 0 && (
          <div class="card">
            <div class="card-titulo"><span class="card-ico">☀️</span> UV</div>
            <div class="card-valor" style={`color:${corUv(uv.indice)}`}>{uv.indice.toFixed(1)}</div>
            <div class="card-sub">{uv.categoria}</div>
            <div class="barra"><div style={`width:${Math.min(100, (uv.indice / 12) * 100)}%; background:${corUv(uv.indice)}`}></div></div>
          </div>
        )}

        <!-- Vento -->
        {vento && (vento.velocidade_kmh != null || vento.max_kmh != null) && (
          <div class="card">
            <div class="card-titulo"><span class="card-ico">🌬️</span> Vento</div>
            <div class="card-valor" style={`color:${corVento(vento.velocidade_kmh ?? vento.max_kmh ?? 0)}`}>
              {vento.velocidade_kmh ?? vento.max_kmh}<span style="font-size:0.35em;"> km/h</span>
            </div>
            <div class="card-sub">
              {vento.direcao ? `de ${vento.direcao}` : ''}{vento.rajada_kmh ? ` · rajada ${vento.rajada_kmh}` : ''}
            </div>
          </div>
        )}

        <!-- Ondas / Surf -->
        {ondas && (
          <div class="card">
            <div class="card-titulo"><span class="card-ico">🏄</span> Ondas</div>
            <div class="duo">
              <span class="card-valor" style="color:#38bdf8;">{(ondas.altura_m ?? ondas.altura_max_m ?? 0).toFixed(1)}<span style="font-size:0.35em;">m</span></span>
              {ondas.periodo_s != null && <span class="card-sub">{ondas.periodo_s.toFixed(0)}s</span>}
            </div>
            <div class="card-sub" style={`color:${SURF_COR[ondas.surf_nivel] ?? '#94a3b8'}; font-weight:700;`}>
              {ondas.surf_emoji} {ondas.surf_descricao}
            </div>
          </div>
        )}

        <!-- Reservatório -->
        {res && res.nivel_pct != null && (
          <div class="card">
            <div class="card-titulo"><span class="card-ico">🌊</span> Represa</div>
            <div class="card-valor" style={`color:${corNivel(res.nivel_pct)}`}>{res.nivel_pct.toFixed(0)}<span style="font-size:0.4em;">%</span></div>
            <div class="card-sub">{res.nome}{res.aproximado ? ' (aprox.)' : ''}</div>
            <div class="barra"><div style={`width:${Math.min(100, res.nivel_pct)}%; background:${corNivel(res.nivel_pct)}`}></div></div>
          </div>
        )}

        <!-- Queimadas -->
        {q && (
          <div class="card">
            <div class="card-titulo"><span class="card-ico">🔥</span> Queimadas</div>
            <div class="card-valor" style={`color:${corFocos(q.focos_100km)}`}>{q.focos_100km}</div>
            <div class="card-sub">focos · raio 100km</div>
          </div>
        )}

        <!-- Dengue -->
        {dengue && dengue.nivel_alerta != null && (
          <div class="card">
            <div class="card-titulo"><span class="card-ico">🦟</span> Dengue</div>
            <div class="card-valor" style={`color:${corDengue(dengue.nivel_alerta)}; font-size:clamp(1rem,3vmin,3.2rem);`}>
              {dengue.nivel_label ?? `Nível ${dengue.nivel_alerta}`}
            </div>
            <div class="card-sub">{dengue.casos_semana} casos/semana</div>
          </div>
        )}

        <!-- Sol -->
        {sol && (
          <div class="card">
            <div class="card-titulo"><span class="card-ico">🌅</span> Sol</div>
            <div class="card-sub" style="font-size:clamp(1rem,2.4vmin,2.6rem); color:#e2e8f0; font-weight:700;">
              <span style="color:#fbbf24;">↑ {sol.nascer}</span> &nbsp; <span style="color:#fb923c;">↓ {sol.por}</span>
            </div>
            {sol.duracao_h != null && <div class="card-sub">{sol.duracao_h}h de luz</div>}
          </div>
        )}

        <!-- Lua -->
        {lua && (
          <div class="card">
            <div class="card-titulo"><span class="card-ico">🌙</span> Lua</div>
            <div class="card-sub" style="font-size:clamp(0.95rem,2.1vmin,2.3rem); color:#e2e8f0; font-weight:700;">
              <span style="font-size:1.5em; vertical-align:middle;">{LUA_EMOJI[lua.nome] ?? '🌙'}</span> {lua.nome}
            </div>
            <div class="card-sub" style="color:#cbd5e1;">
              {lua.iluminacao_pct}% iluminada{lua.dias_proxima_cheia != null ? (lua.dias_proxima_cheia === 0 ? ' · cheia hoje' : ` · cheia em ${lua.dias_proxima_cheia} ${lua.dias_proxima_cheia === 1 ? 'dia' : 'dias'}`) : ''}
            </div>
          </div>
        )}
      </div>
    </div>

    <script>
      // Plano de fundo dia/noite: compara o horário local com nascer/pôr do sol
      const nascer = document.body.dataset.nascer || '';
      const por = document.body.dataset.por || '';
      function aplicarNoite() {
        if (!nascer || !por) return;
        const agora = new Date().toLocaleTimeString('pt-BR', {
          timeZone: 'America/Sao_Paulo', hour: '2-digit', minute: '2-digit', hour12: false,
        });
        document.body.classList.toggle('noite', agora < nascer || agora >= por);
      }

      // Relógio em tempo real
      function tick() {
        const agora = new Date();
        const rel = document.getElementById('relogio');
        const dh = document.getElementById('data-hoje');
        if (rel) rel.textContent = agora.toLocaleTimeString('pt-BR', { timeZone: 'America/Sao_Paulo' });
        if (dh) dh.textContent = agora.toLocaleDateString('pt-BR', {
          timeZone: 'America/Sao_Paulo', weekday: 'long', day: '2-digit', month: 'long',
        });
        aplicarNoite();
      }
      tick();
      setInterval(tick, 1000);

      // Hidratação em tempo real pela mesma fonte/cache da página da cidade
      // (Open-Meteo no browser), para o painel não divergir do snapshot do build.
      const lat = parseFloat(document.body.dataset.lat || '');
      const lon = parseFloat(document.body.dataset.lon || '');

      const WMO: Record<number, string> = {
        0: 'Céu limpo', 1: 'Principalmente limpo', 2: 'Parcialmente nublado', 3: 'Encoberto',
        45: 'Névoa', 48: 'Névoa com gelo', 51: 'Chuvisco leve', 53: 'Chuvisco moderado', 55: 'Chuvisco denso',
        61: 'Chuva leve', 63: 'Chuva moderada', 65: 'Chuva forte', 71: 'Neve leve', 73: 'Neve moderada', 75: 'Neve forte',
        77: 'Granizo', 80: 'Chuva isolada leve', 81: 'Chuva isolada moderada', 82: 'Chuva isolada forte',
        85: 'Neve isolada', 86: 'Neve isolada forte', 95: 'Tempestade', 96: 'Tempestade com granizo leve', 99: 'Tempestade com granizo forte',
      };
      const EMOJI: Record<number, string> = {
        0: '☀️', 1: '🌤', 2: '⛅', 3: '☁️', 45: '🌫', 48: '🌫', 51: '🌦', 53: '🌦', 55: '🌧',
        61: '🌧', 63: '🌧', 65: '🌧', 71: '❄️', 73: '❄️', 75: '❄️', 77: '🌨', 80: '🌦', 81: '🌦',
        82: '⛈', 95: '⛈', 96: '⛈', 99: '⛈',
      };
      const TEMAS = ['clima-limpo', 'clima-nublado', 'clima-encoberto', 'clima-chuva', 'clima-neve', 'clima-tempestade'];
      function temaDoTempo(c: number): string {
        if (!Number.isFinite(c)) return 'clima-limpo';
        if (c <= 1) return 'clima-limpo';
        if (c === 2) return 'clima-nublado';
        if (c === 3 || c === 45 || c === 48) return 'clima-encoberto';
        if ((c >= 51 && c <= 67) || (c >= 80 && c <= 82)) return 'clima-chuva';
        if ((c >= 71 && c <= 77) || c === 85 || c === 86) return 'clima-neve';
        if (c >= 95) return 'clima-tempestade';
        return 'clima-limpo';
      }
      const arred = (n: number) => Math.round(n * 10) / 10;
      function diaSemana(dataStr: string): string {
        return new Date(dataStr + 'T12:00:00').toLocaleDateString('pt-BR', { weekday: 'short' }).slice(0, 3);
      }

      async function hidratarClima() {
        if (!Number.isFinite(lat) || !Number.isFinite(lon)) return;
        const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}`
          + `&current=temperature_2m,weather_code,relative_humidity_2m,pressure_msl,dew_point_2m`
          + `&daily=temperature_2m_max,temperature_2m_min,weather_code,precipitation_sum`
          + `&timezone=America%2FSao_Paulo&forecast_days=7`;
        const chave = `om:${lat},${lon}`;

        let data: any;
        try {
          const raw = sessionStorage.getItem(chave);
          if (raw) { const o = JSON.parse(raw); if (Date.now() - o.t < 600000) data = o.d; }
        } catch { /* ignora */ }
        if (!data) {
          try {
            const res = await fetch(url);
            if (!res.ok) return;
            data = await res.json();
            try { sessionStorage.setItem(chave, JSON.stringify({ t: Date.now(), d: data })); } catch { /* ignora */ }
          } catch { return; } // mantém o snapshot
        }

        // Temperatura atual + tema de fundo + condição (ao vivo)
        const cur = data?.current;

        // Condições do ar: umidade, pressão, ponto de orvalho
        const arCondEl = document.getElementById('ar-cond');
        if (arCondEl && cur) {
          const partes: string[] = [];
          if (typeof cur.relative_humidity_2m === 'number') partes.push(`💧${Math.round(cur.relative_humidity_2m)}%`);
          if (typeof cur.pressure_msl === 'number') partes.push(`${Math.round(cur.pressure_msl)}hPa`);
          if (typeof cur.dew_point_2m === 'number') partes.push(`🌡${Math.round(cur.dew_point_2m)}°`);
          if (partes.length) arCondEl.textContent = ' · ' + partes.join(' · ');
        }

        if (cur && typeof cur.temperature_2m === 'number') {
          const tEl = document.getElementById('temp-atual');
          if (tEl) { tEl.textContent = `${arred(cur.temperature_2m)}°`; tEl.hidden = false; }

          const code = Number(cur.weather_code);
          if (Number.isFinite(code)) {
            document.body.classList.remove(...TEMAS);
            document.body.classList.add(temaDoTempo(code));
            const condEl = document.getElementById('condicao');
            if (condEl) { condEl.textContent = `${EMOJI[code] ?? '⛅'} ${WMO[code] ?? ''}`; condEl.hidden = false; }
            aplicarNoite();
            // Marca d'água do fundo: à noite com céu limpo, mostra a lua
            const icoEl = document.getElementById('cena-icone');
            if (icoEl) {
              const noite = document.body.classList.contains('noite');
              icoEl.textContent = (noite && code <= 1) ? '🌙' : (EMOJI[code] ?? '⛅');
            }
          }
        }

        // Previsão: hoje (duo) + próximos 6 dias
        const daily = data?.daily;
        if (daily && Array.isArray(daily.time) && daily.time.length) {
          const setF = (root: ParentNode, f: string, v: string) => {
            const el = root.querySelector<HTMLElement>(`[data-f="${f}"]`);
            if (el) el.textContent = v;
          };
          const card = document.querySelector<HTMLElement>('.card-wide');
          if (card) {
            setF(card, 'max', `${Math.round(daily.temperature_2m_max[0])}°`);
            setF(card, 'min', `${Math.round(daily.temperature_2m_min[0])}°`);
            const chuva = arred(daily.precipitation_sum?.[0] ?? 0);
            const chuvaEl = card.querySelector<HTMLElement>('[data-f="chuva"]');
            if (chuvaEl) {
              if (chuva > 0) { chuvaEl.textContent = `💧${chuva}mm`; chuvaEl.hidden = false; }
              else chuvaEl.hidden = true;
            }
          }
          const dias = document.querySelectorAll<HTMLElement>('[data-prev-dias] [data-dia]');
          dias.forEach((dia, i) => {
            const idx = i + 1; // pula hoje
            if (idx >= daily.time.length) return;
            setF(dia, 'd', diaSemana(daily.time[idx]));
            setF(dia, 'e', EMOJI[Number(daily.weather_code[idx])] ?? '⛅');
            setF(dia, 'tmax', `${Math.round(daily.temperature_2m_max[idx])}°`);
            setF(dia, 'tmin', `${Math.round(daily.temperature_2m_min[idx])}°`);
          });
        }
      }
      hidratarClima();

      // Botão tela cheia
      const fsBtn = document.getElementById('fs-btn');
      fsBtn?.addEventListener('click', () => {
        if (!document.fullscreenElement) {
          document.documentElement.requestFullscreen?.();
        } else {
          document.exitFullscreen?.();
        }
      });

      // Atalho: F entra/sai fullscreen, Esc volta
      document.addEventListener('keydown', (e) => {
        if (e.key === 'f' || e.key === 'F') fsBtn?.click();
      });

      // Recarrega a cada 10 min para manter dados frescos no telão
      setTimeout(() => location.reload(), 10 * 60 * 1000);
    </script>
  </body>
</html>
