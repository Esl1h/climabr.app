---
// Modo Mobile — página única client-rendered (uma só rota, não gera arquivo por
// cidade, respeitando o limite de 20k arquivos do Pages free). Lê a cidade de
// ?c=uf/slug, busca /api/{uf}/{cidade}.json, renderiza os tiles e mescla os dados
// ao vivo do Open-Meteo. Visual baseado no Modo Painel (telão).
const titulo = 'Modo Mobile — climabr.app';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{titulo}</title>
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#020617" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root { --gap: clamp(0.5rem, 1.4vmin, 1.4rem); }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; height: 100%; background: #020617; }
      html { font-size: 11px; }
      body { font-family: system-ui, -apple-system, sans-serif; color: #f1f5f9; overflow: hidden; }

      .cena { position: fixed; inset: 0; z-index: 0; background: linear-gradient(160deg, #0f172a, #1e293b); transition: background 1.5s ease, filter 1.5s ease; }
      .cena::before { content: ''; position: absolute; inset: -25%; background: radial-gradient(circle, var(--glow, rgba(255,255,255,0.06)), transparent 60%); animation: flutua 22s ease-in-out infinite alternate; }
      @keyframes flutua { from { transform: translate(-6%, -4%) scale(1); } to { transform: translate(6%, 5%) scale(1.15); } }
      .cena-icone { position: fixed; z-index: 0; right: 3vmin; bottom: 0; font-size: clamp(7rem, 40vmin, 22rem); line-height: 1; opacity: 0.14; pointer-events: none; user-select: none; animation: respira 9s ease-in-out infinite alternate; }
      @keyframes respira { from { transform: scale(1); } to { transform: scale(1.06); } }
      .clima-limpo .cena      { --glow: rgba(250,204,21,0.28); background: radial-gradient(circle at 78% 18%, rgba(250,204,21,0.30), transparent 42%), linear-gradient(160deg, #075985, #0c4a6e 55%, #0e7490); }
      .clima-nublado .cena    { --glow: rgba(148,163,184,0.20); background: linear-gradient(160deg, #1e293b, #334155 60%, #475569); }
      .clima-encoberto .cena  { --glow: rgba(148,163,184,0.16); background: linear-gradient(160deg, #1f2937, #374151 60%, #4b5563); }
      .clima-chuva .cena      { --glow: rgba(59,130,246,0.20); background: radial-gradient(circle at 50% -10%, rgba(59,130,246,0.22), transparent 50%), linear-gradient(160deg, #0f172a, #1e3a5f 60%, #1e293b); }
      .clima-neve .cena       { --glow: rgba(226,232,240,0.25); background: linear-gradient(160deg, #334155, #475569 55%, #64748b); }
      .clima-tempestade .cena { --glow: rgba(167,139,250,0.28); background: radial-gradient(circle at 30% 8%, rgba(167,139,250,0.28), transparent 45%), linear-gradient(160deg, #0f0a1f, #1e1b4b 55%, #312e81); }
      .noite .cena { filter: brightness(0.6) saturate(0.85); }

      .telao { position: relative; z-index: 1; height: 100dvh; max-width: 480px; margin: 0 auto; display: flex; flex-direction: column; padding: var(--gap); gap: var(--gap); }
      .topo { display: flex; flex-direction: column; align-items: center; text-align: center; gap: calc(var(--gap) * 0.4); border-bottom: 1px solid rgba(148,163,184,0.22); padding-bottom: var(--gap); }
      .topo-linha { display: flex; align-items: baseline; justify-content: center; flex-wrap: wrap; gap: var(--gap); }
      .cidade-nome { font-size: clamp(1.8rem, 9vmin, 3rem); font-weight: 800; line-height: 1; letter-spacing: -0.01em; }
      .cidade-uf { color: #cbd5e1; font-weight: 400; font-size: 0.5em; opacity: 0.7; }
      .temp-atual { font-size: clamp(1.8rem, 9vmin, 3rem); font-weight: 800; color: #7dd3fc; line-height: 1; }
      .clima-linha { display: flex; justify-content: center; align-items: center; gap: 0.5em; flex-wrap: wrap; color: #e2e8f0; font-weight: 600; font-size: clamp(0.9rem, 3.6vmin, 1.3rem); }
      .clima-linha .estacao { display: inline-flex; align-items: center; gap: 0.35em; opacity: 0.92; }
      .clima-linha .sep { opacity: 0.35; margin-right: 0.35em; font-weight: 400; }
      .marca { font-size: clamp(0.8rem, 3vmin, 1.1rem); color: #cbd5e1; }

      .grid { flex: 1; display: grid; grid-template-columns: 1fr 1fr; grid-auto-rows: minmax(0, 1fr); gap: var(--gap); min-height: 0; align-content: stretch; }
      .card { position: relative; background: rgba(15,23,42,0.55); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(148,163,184,0.16); border-radius: clamp(0.6rem, 1.6vmin, 1.4rem); box-shadow: 0 10px 34px rgba(0,0,0,0.35); padding: clamp(0.6rem, 2vmin, 1.4rem); display: flex; flex-direction: column; justify-content: center; gap: clamp(0.2rem, 0.7vmin, 0.6rem); overflow: hidden; min-height: 0; text-align: center; }
      .card-wide { grid-column: span 2; }
      .card-titulo { font-size: clamp(0.7rem, 2.4vmin, 1.1rem); color: #cbd5e1; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; display: flex; align-items: center; justify-content: center; gap: 0.4em; }
      .card-valor { font-size: clamp(1.6rem, 7vmin, 2.6rem); font-weight: 800; line-height: 1; }
      .card-sub { font-size: clamp(0.7rem, 2.4vmin, 1.1rem); color: #94a3b8; }
      .card-ico { font-size: clamp(1rem, 3.6vmin, 1.5rem); }
      .duo { display: flex; gap: 0.8em; align-items: baseline; justify-content: center; }
      .prev-dias { display: flex; gap: clamp(0.2rem, 0.8vmin, 0.6rem); justify-content: space-between; }
      .prev-dia { text-align: center; flex: 1; }
      .prev-dia .d { font-size: clamp(0.65rem, 2.2vmin, 1rem); color: #94a3b8; text-transform: capitalize; }
      .prev-dia .e { font-size: clamp(1.1rem, 4.6vmin, 1.8rem); }
      .prev-dia .t { font-size: clamp(0.7rem, 2.4vmin, 1.1rem); font-weight: 700; }
      .barra { height: clamp(0.35rem, 1vmin, 0.7rem); background: rgba(148,163,184,0.25); border-radius: 99px; overflow: hidden; }
      .barra > div { height: 100%; border-radius: 99px; }

      .canto { position: fixed; top: var(--gap); right: var(--gap); z-index: 10; opacity: 0.4; }
      .canto a { background: rgba(30,41,59,0.7); color: #e2e8f0; border: 1px solid rgba(148,163,184,0.3); border-radius: 0.6rem; padding: 0.4rem 0.6rem; font-size: 1rem; text-decoration: none; }

      #aviso { position: fixed; inset: 0; display: flex; align-items: center; justify-content: center; text-align: center; padding: 2rem; color: #94a3b8; font-size: 1.2rem; z-index: 2; }
      @media (prefers-reduced-motion: reduce) { .cena::before, .cena-icone { animation: none; } }
    </style>
  </head>
  <body>
    <div class="cena"></div>
    <div class="cena-icone" id="cena-icone"></div>
    <div class="canto"><a id="sair" href="/" title="Sair">✕</a></div>

    <div class="telao" id="telao" hidden>
      <div class="topo">
        <div class="topo-linha">
          <div class="temp-atual" id="temp-atual" hidden></div>
          <div class="cidade-nome" id="cidade-nome"></div>
        </div>
        <div class="clima-linha" id="clima-linha" hidden>
          <span id="condicao"></span>
          <span class="estacao" id="estacao" hidden></span>
        </div>
        <div class="topo-linha">
          <span class="marca"><span aria-hidden="true" style="margin-right:0.3em;">🛰️</span><span style="color:#10b981; font-weight:700; font-style:italic;">Clima<span style="color:#3b82f6;">BR</span><span style="color:#eab308; font-style:normal;">.app</span></span></span>
        </div>
      </div>
      <div class="grid" id="grid"></div>
    </div>

    <div id="aviso">Carregando…</div>

    <script>
      const TEMPO_EMOJI: Record<number, string> = { 0:'☀️',1:'🌤',2:'⛅',3:'☁️',45:'🌫',48:'🌫',51:'🌦',53:'🌦',55:'🌧',61:'🌧',63:'🌧',65:'🌧',71:'❄️',73:'❄️',75:'❄️',77:'🌨',80:'🌦',81:'🌦',82:'⛈',85:'🌨',86:'🌨',95:'⛈',96:'⛈',99:'⛈' };
      const LUA_EMOJI: Record<string, string> = { 'Nova':'🌑','Crescente':'🌒','Quarto Crescente':'🌓','Gibosa Crescente':'🌔','Cheia':'🌕','Gibosa Minguante':'🌖','Quarto Minguante':'🌗','Minguante':'🌘' };
      const WMO: Record<number, string> = { 0:'Céu limpo',1:'Principalmente limpo',2:'Parcialmente nublado',3:'Encoberto',45:'Névoa',48:'Névoa com gelo',51:'Chuvisco leve',53:'Chuvisco moderado',55:'Chuvisco denso',61:'Chuva leve',63:'Chuva moderada',65:'Chuva forte',71:'Neve leve',73:'Neve moderada',75:'Neve forte',77:'Granizo',80:'Chuva isolada leve',81:'Chuva isolada moderada',82:'Chuva isolada forte',95:'Tempestade',96:'Tempestade com granizo leve',99:'Tempestade com granizo forte' };
      const SURF_COR: Record<string, string> = { bom:'#34d399', razoavel:'#fbbf24', ruim:'#f87171', perigoso:'#ef4444', desconhecido:'#94a3b8' };
      const corAqi = (i: number) => i <= 50 ? '#34d399' : i <= 100 ? '#fbbf24' : i <= 150 ? '#fb923c' : '#f87171';
      const corUv = (i: number) => i < 3 ? '#34d399' : i < 6 ? '#fbbf24' : i < 8 ? '#fb923c' : i < 11 ? '#f87171' : '#a78bfa';
      const corNivel = (p: number) => p >= 70 ? '#34d399' : p >= 40 ? '#fbbf24' : '#f87171';
      const corVento = (v: number) => v < 20 ? '#34d399' : v < 40 ? '#fbbf24' : v < 60 ? '#fb923c' : '#f87171';
      const corDengue = (n: number) => ['#34d399','#fbbf24','#fb923c','#f87171','#ef4444'][n] ?? '#94a3b8';
      const corFocos = (f: number) => f === 0 ? '#34d399' : f <= 5 ? '#fbbf24' : f <= 20 ? '#fb923c' : '#f87171';
      const catUv = (uv: number) => uv < 3 ? 'Baixo' : uv < 6 ? 'Moderado' : uv < 8 ? 'Alto' : uv < 11 ? 'Muito Alto' : 'Extremo';
      const catAqi = (a: number) => a <= 50 ? 'Boa' : a <= 100 ? 'Moderada' : a <= 150 ? 'Ruim para grupos sensíveis' : a <= 200 ? 'Ruim' : a <= 300 ? 'Muito Ruim' : 'Perigosa';
      const arred = (n: number) => Math.round(n * 10) / 10;
      const grau = (d: number) => ['N','NE','L','SE','S','SO','O','NO'][Math.round(d / 45) % 8];
      const esc = (s: any) => String(s ?? '').replace(/[&<>"]/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c] as string));

      function temaDoTempo(c: number): string {
        if (!Number.isFinite(c)) return 'clima-limpo';
        if (c <= 1) return 'clima-limpo';
        if (c === 2) return 'clima-nublado';
        if (c === 3 || c === 45 || c === 48) return 'clima-encoberto';
        if ((c >= 51 && c <= 67) || (c >= 80 && c <= 82)) return 'clima-chuva';
        if ((c >= 71 && c <= 77) || c === 85 || c === 86) return 'clima-neve';
        if (c >= 95) return 'clima-tempestade';
        return 'clima-limpo';
      }
      function iconeEstacao(e: string): string {
        const n = (e || '').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
        if (n.includes('verao')) return '🌻';
        if (n.includes('outono')) return '🍂';
        if (n.includes('inverno')) return '❄️';
        if (n.includes('primavera')) return '🌸';
        return '📅';
      }
      function diaSemana(s: string): string {
        return new Date(s + 'T12:00:00').toLocaleDateString('pt-BR', { weekday: 'short' }).slice(0, 3);
      }

      function tiles(d: any): string {
        const out: string[] = [];
        const prev = d.previsao ?? [];
        const hoje = prev[0];
        if (prev.length) {
          const dias = prev.slice(1, 7).map((x: any) => `<div class="prev-dia"><div class="d">${diaSemana(x.data)}</div><div class="e">${TEMPO_EMOJI[x.condicao_codigo] ?? '⛅'}</div><div class="t" style="color:#f87171">${Math.round(x.max)}°</div><div class="t" style="color:#64748b">${Math.round(x.min)}°</div></div>`).join('');
          out.push(`<div class="card card-wide"><div class="card-titulo"><span class="card-ico">⛅</span> Previsão</div>${hoje ? `<div class="duo"><span class="card-valor" style="color:#f87171">${Math.round(hoje.max)}°</span><span class="card-valor" style="color:#38bdf8;font-size:clamp(1.2rem,5vmin,1.9rem)">${Math.round(hoje.min)}°</span>${hoje.chuva_mm > 0 ? `<span class="card-sub">💧${hoje.chuva_mm}mm</span>` : ''}</div>` : ''}<div class="prev-dias">${dias}</div></div>`);
        }
        const ar = d.qualidade_ar;
        if (ar) out.push(`<div class="card"><div class="card-titulo"><span class="card-ico">💨</span> Ar</div><div class="card-valor" style="color:${corAqi(ar.indice)}">${ar.indice}</div><div class="card-sub">${esc(ar.categoria)}</div><div class="barra"><div style="width:${Math.min(100, ar.indice / 3)}%;background:${corAqi(ar.indice)}"></div></div></div>`);
        const uv = d.uv;
        if (uv && uv.indice > 0) out.push(`<div class="card"><div class="card-titulo"><span class="card-ico">☀️</span> UV</div><div class="card-valor" style="color:${corUv(uv.indice)}">${uv.indice.toFixed(1)}</div><div class="card-sub">${esc(uv.categoria)}</div><div class="barra"><div style="width:${Math.min(100, uv.indice / 12 * 100)}%;background:${corUv(uv.indice)}"></div></div></div>`);
        const v = d.vento;
        if (v && (v.velocidade_kmh != null || v.max_kmh != null)) { const kmh = v.velocidade_kmh ?? v.max_kmh; out.push(`<div class="card"><div class="card-titulo"><span class="card-ico">🌬️</span> Vento</div><div class="card-valor" style="color:${corVento(kmh)}">${kmh}<span style="font-size:0.35em"> km/h</span></div><div class="card-sub">${v.direcao ? 'de ' + esc(v.direcao) : ''}${v.rajada_kmh ? ' · rajada ' + v.rajada_kmh : ''}</div></div>`); }
        const o = d.ondas;
        if (o) out.push(`<div class="card"><div class="card-titulo"><span class="card-ico">🏄</span> Ondas</div><div class="card-valor" style="color:#38bdf8">${(o.altura_m ?? o.altura_max_m ?? 0).toFixed(1)}<span style="font-size:0.35em">m</span></div><div class="card-sub" style="color:${SURF_COR[o.surf_nivel] ?? '#94a3b8'};font-weight:700">${o.surf_emoji ?? ''} ${esc(o.surf_descricao ?? '')}</div></div>`);
        const r = d.reservatorio;
        if (r && r.nivel_pct != null) out.push(`<div class="card"><div class="card-titulo"><span class="card-ico">🌊</span> Represa</div><div class="card-valor" style="color:${corNivel(r.nivel_pct)}">${r.nivel_pct.toFixed(0)}<span style="font-size:0.4em">%</span></div><div class="card-sub">${esc(r.nome)}${r.aproximado ? ' (aprox.)' : ''}</div><div class="barra"><div style="width:${Math.min(100, r.nivel_pct)}%;background:${corNivel(r.nivel_pct)}"></div></div></div>`);
        const q = d.queimadas;
        if (q) out.push(`<div class="card"><div class="card-titulo"><span class="card-ico">🔥</span> Queimadas</div><div class="card-valor" style="color:${corFocos(q.focos_100km)}">${q.focos_100km}</div><div class="card-sub">focos · raio 100km</div></div>`);
        const dg = d.dengue;
        if (dg && dg.nivel_alerta != null) out.push(`<div class="card"><div class="card-titulo"><span class="card-ico">🦟</span> Dengue</div><div class="card-valor" style="color:${corDengue(dg.nivel_alerta)};font-size:clamp(1rem,4.5vmin,1.6rem)">${esc(dg.nivel_label ?? 'Nível ' + dg.nivel_alerta)}</div><div class="card-sub">${dg.casos_semana ?? 0} casos/sem</div></div>`);
        const s = d.sol;
        if (s) out.push(`<div class="card"><div class="card-titulo"><span class="card-ico">🌅</span> Sol</div><div class="card-sub" style="font-size:clamp(0.85rem,3vmin,1.2rem);color:#e2e8f0;font-weight:700"><span style="color:#fbbf24">↑ ${esc(s.nascer)}</span> <span style="color:#fb923c">↓ ${esc(s.por)}</span></div>${s.duracao_h != null ? `<div class="card-sub">${s.duracao_h}h de luz</div>` : ''}</div>`);
        const l = d.lua;
        if (l) out.push(`<div class="card"><div class="card-titulo"><span class="card-ico">🌙</span> Lua</div><div class="card-sub" style="font-size:clamp(0.8rem,2.8vmin,1.1rem);color:#e2e8f0;font-weight:700"><span style="font-size:1.5em;vertical-align:middle">${LUA_EMOJI[l.nome] ?? '🌙'}</span> ${esc(l.nome)}</div><div class="card-sub">${l.iluminacao_pct}% iluminada</div></div>`);
        return out.join('');
      }

      function render(d: any, nome: string, uf: string) {
        const hoje = (d.previsao ?? [])[0];
        document.getElementById('cidade-nome')!.innerHTML = `${esc(nome)}<span class="cidade-uf">/${esc(uf.toUpperCase())}</span>`;
        const tEl = document.getElementById('temp-atual')!;
        if (d.temperatura_atual != null) { tEl.textContent = `${d.temperatura_atual}°`; tEl.hidden = false; } else { tEl.hidden = true; }
        const cl = document.getElementById('clima-linha')!;
        const cond = document.getElementById('condicao')!;
        const est = document.getElementById('estacao')!;
        if (hoje) cond.textContent = `${TEMPO_EMOJI[hoje.condicao_codigo] ?? '⛅'} ${hoje.condicao ?? ''}`;
        const estacao = d.sol?.estacao;
        if (estacao) { est.textContent = `${iconeEstacao(estacao)} ${estacao}`; est.hidden = false; }
        cl.hidden = !(hoje || estacao);
        document.getElementById('grid')!.innerHTML = tiles(d);
        const ico = document.getElementById('cena-icone')!;
        ico.textContent = hoje ? (TEMPO_EMOJI[hoje.condicao_codigo] ?? '⛅') : '⛅';
        document.body.className = temaDoTempo(Number(hoje?.condicao_codigo));
        aplicarNoite(d.sol?.nascer, d.sol?.por);
      }

      function aplicarNoite(nascer?: string, por?: string) {
        if (!nascer || !por) return;
        const agora = new Date().toLocaleTimeString('pt-BR', { timeZone: 'America/Sao_Paulo', hour: '2-digit', minute: '2-digit', hour12: false });
        document.body.classList.toggle('noite', agora < nascer || agora >= por);
      }

      async function buscarLive(lat: number, lon: number) {
        const fc = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current=temperature_2m,weather_code,wind_speed_10m,wind_direction_10m&daily=temperature_2m_max,temperature_2m_min,weather_code,precipitation_sum,uv_index_max&timezone=America%2FSao_Paulo&forecast_days=7`;
        const aq = `https://air-quality-api.open-meteo.com/v1/air-quality?latitude=${lat}&longitude=${lon}&current=us_aqi,pm2_5&timezone=America%2FSao_Paulo`;
        const [om, ar] = await Promise.all([
          fetch(fc).then(r => r.ok ? r.json() : null).catch(() => null),
          fetch(aq).then(r => r.ok ? r.json() : null).catch(() => null),
        ]);
        return { om, ar };
      }

      function mesclar(d: any, om: any, ar: any) {
        if (om?.current?.temperature_2m != null) d.temperatura_atual = arred(om.current.temperature_2m);
        const dy = om?.daily;
        if (dy && Array.isArray(dy.time)) {
          d.previsao = dy.time.slice(0, 7).map((t: string, i: number) => ({
            data: t, max: arred(dy.temperature_2m_max[i]), min: arred(dy.temperature_2m_min[i]),
            chuva_mm: arred(dy.precipitation_sum?.[i] ?? 0),
            condicao: WMO[dy.weather_code[i]] ?? '', condicao_codigo: dy.weather_code[i],
          }));
          if (dy.uv_index_max?.[0] != null) d.uv = { indice: arred(dy.uv_index_max[0]), categoria: catUv(arred(dy.uv_index_max[0])) };
        }
        if (om?.current?.wind_speed_10m != null) {
          d.vento = { ...(d.vento ?? {}), velocidade_kmh: Math.round(om.current.wind_speed_10m), direcao: grau(om.current.wind_direction_10m ?? 0) };
        }
        if (ar?.current?.us_aqi != null) {
          const a = Math.round(ar.current.us_aqi);
          d.qualidade_ar = { ...(d.qualidade_ar ?? {}), indice: a, categoria: catAqi(a), pm25: ar.current.pm2_5 != null ? arred(ar.current.pm2_5) : d.qualidade_ar?.pm25 };
        }
        return d;
      }

      async function main() {
        const params = new URLSearchParams(location.search);
        const c = (params.get('c') || '').toLowerCase();
        const m = c.match(/^([a-z]{2})[\/-]([a-z0-9-]+)$/);
        const aviso = document.getElementById('aviso')!;
        if (!m) { aviso.innerHTML = 'Informe a cidade: <code>/mobile?c=sp/sao-paulo</code>'; return; }
        const [, uf, slug] = m;
        document.getElementById('sair')!.setAttribute('href', `/${uf}/${slug}`);

        let dados: any = null;
        try {
          const res = await fetch(`/api/${uf}/${slug}.json`);
          if (res.ok) dados = await res.json();
        } catch { /* rede */ }
        if (!dados || dados._status) { aviso.textContent = 'Cidade não encontrada ou sem dados.'; return; }

        const nome = dados.cidade || slug;
        aviso.hidden = true;
        document.getElementById('telao')!.hidden = false;
        document.title = `${nome}/${uf.toUpperCase()} — Modo Mobile — climabr.app`;
        render(dados, nome, uf);

        const lat = Number(dados.latitude), lon = Number(dados.longitude);
        if (Number.isFinite(lat) && Number.isFinite(lon)) {
          const { om, ar } = await buscarLive(lat, lon);
          if (om || ar) render(mesclar(dados, om, ar), nome, uf);
        }
        setInterval(() => aplicarNoite(dados.sol?.nascer, dados.sol?.por), 60000);
      }
      main();
    </script>
  </body>
</html>
