---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  cidade?: string;
  estado?: string;
  slug?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Painel ambiental brasileiro por cidade — qualidade do ar, água, clima e alertas.',
  cidade,
  estado,
  slug,
  ogImage,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, 'https://climabr.app').href;
const ogTitle = cidade && estado ? `${cidade}/${estado.toUpperCase()} — ClimaBR.app` : title;

// Em páginas de cidade: card PNG (gerado pelo Worker) como imagem social.
// PNG tem suporte universal (Twitter/X, Facebook, WhatsApp). O SVG fica como alternativo.
const cardImage = ogImage ?? (estado && slug ? `https://climabr.app/${estado}/${slug}.png` : undefined);
const jsonHref = estado && slug ? `https://climabr.app/api/${estado}/${slug}.json` : undefined;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Crawlers (web + AI) -->
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="googlebot" content="index, follow" />

    <!-- Acesso programático e AI-first -->
    {jsonHref && <link rel="alternate" type="application/json" href={jsonHref} title="Dados em JSON" />}
    <link rel="alternate" type="text/plain" href="/llms.txt" title="llms.txt" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="ClimaBR.app" />
    <meta property="og:locale" content="pt_BR" />
    {cardImage && <meta property="og:image" content={cardImage} />}
    {cardImage && <meta property="og:image:type" content="image/png" />}
    {cardImage && <meta property="og:image:alt" content={ogTitle} />}

    <!-- Twitter / X -->
    <meta name="twitter:card" content={cardImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    {cardImage && <meta name="twitter:image" content={cardImage} />}

    <!-- PWA / theme -->
    <meta name="theme-color" content="#0f172a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 antialiased">
    <header class="border-b border-slate-800 px-4 py-3">
      <div class="flex items-center justify-between max-w-3xl mx-auto">
        <!-- Logo -->
        <a href="/" class="text-lg font-bold tracking-tight hover:opacity-80 transition-opacity">
          <span aria-hidden="true" class="not-italic mr-1">🛰️</span><span class="italic text-emerald-700">Clima</span><span class="italic text-blue-600">BR</span><span class="text-yellow-500">.app</span>
        </a>

        <!-- Menu hamburguer -->
        <div class="relative" id="menu-wrapper">
          <button
            id="menu-btn"
            aria-label="Menu"
            aria-expanded="false"
            class="flex flex-col justify-center gap-1.5 w-8 h-8 p-1 rounded hover:bg-slate-800 transition-colors"
          >
            <span class="block h-0.5 w-full bg-slate-400 transition-all" id="bar1"></span>
            <span class="block h-0.5 w-full bg-slate-400 transition-all" id="bar2"></span>
            <span class="block h-0.5 w-full bg-slate-400 transition-all" id="bar3"></span>
          </button>

          <nav
            id="menu-dropdown"
            class="hidden absolute right-0 top-10 w-48 bg-slate-900 border border-slate-700 rounded-lg shadow-xl z-50 py-1"
            role="menu"
          >
            <a
              id="menu-telao"
              href="#"
              class="hidden items-center gap-2 px-4 py-2.5 text-sm text-slate-300 hover:bg-slate-800 hover:text-white transition-colors"
              role="menuitem"
            >
              <span class="text-emerald-400 text-xs">📺</span>
              Modo Painel
            </a>
            <a
              href="/curl"
              class="flex items-center gap-2 px-4 py-2.5 text-sm text-slate-300 hover:bg-slate-800 hover:text-white transition-colors"
              role="menuitem"
            >
              <span class="font-mono text-emerald-400 text-xs bg-slate-800 px-1.5 py-0.5 rounded">$</span>
              cUrl
            </a>
            <div class="border-t border-slate-800 my-1"></div>
            <a
              href="/llms.txt"
              class="flex items-center gap-2 px-4 py-2.5 text-sm text-slate-300 hover:bg-slate-800 hover:text-white transition-colors"
              role="menuitem"
              target="_blank"
            >
              <span class="text-slate-500 text-xs">AI</span>
              llms.txt
            </a>
            <a
              href="/.well-known/mcp.json"
              class="flex items-center gap-2 px-4 py-2.5 text-sm text-slate-300 hover:bg-slate-800 hover:text-white transition-colors"
              role="menuitem"
              target="_blank"
            >
              <span class="text-slate-500 text-xs">MCP</span>
              mcp.json
            </a>
          </nav>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-4 py-8">
      <slot />
    </main>

    <footer class="mt-16 border-t border-slate-800 px-4 py-6 text-center text-xs text-slate-500">
      Dados de fontes públicas: INMET, ANA, INPE, CETESB, SVS/MS, ANEEL &nbsp;·&nbsp;
      <a href="/llms.txt" class="underline hover:text-slate-300">llms.txt</a>
    </footer>

    <script>
      const btn = document.getElementById('menu-btn');
      const dropdown = document.getElementById('menu-dropdown');
      const bar1 = document.getElementById('bar1');
      const bar2 = document.getElementById('bar2');
      const bar3 = document.getElementById('bar3');

      function toggleMenu() {
        const open = dropdown?.classList.toggle('hidden') === false;
        btn?.setAttribute('aria-expanded', String(open));
        if (open) {
          bar1?.classList.add('rotate-45', 'translate-y-2');
          bar2?.classList.add('opacity-0');
          bar3?.classList.add('-rotate-45', '-translate-y-2');
        } else {
          bar1?.classList.remove('rotate-45', 'translate-y-2');
          bar2?.classList.remove('opacity-0');
          bar3?.classList.remove('-rotate-45', '-translate-y-2');
        }
      }

      btn?.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleMenu();
      });

      // Fecha ao clicar fora
      document.addEventListener('click', () => {
        if (!dropdown?.classList.contains('hidden')) {
          dropdown?.classList.add('hidden');
          btn?.setAttribute('aria-expanded', 'false');
          bar1?.classList.remove('rotate-45', 'translate-y-2');
          bar2?.classList.remove('opacity-0');
          bar3?.classList.remove('-rotate-45', '-translate-y-2');
        }
      });

      // Modo Telão: só aparece em páginas de cidade (/uf/slug)
      const telaoLink = document.getElementById('menu-telao');
      const m = location.pathname.match(/^\/([a-z]{2})\/([a-z0-9-]+)\/?$/);
      if (telaoLink && m) {
        telaoLink.setAttribute('href', `/${m[1]}/${m[2]}/telao`);
        telaoLink.classList.remove('hidden');
        telaoLink.classList.add('flex');
      }
    </script>
  </body>
</html>
