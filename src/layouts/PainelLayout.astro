---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  cidade?: string;
  estado?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Painel ambiental brasileiro por cidade — qualidade do ar, água, clima e alertas.',
  cidade,
  estado,
  ogImage,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, 'https://climabr.app').href;
const ogTitle = cidade && estado ? `${cidade}/${estado.toUpperCase()} — climabr` : title;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- AI crawlers -->
    <meta name="robots" content="index, follow" />
    <meta name="GPTBot" content="index" />
    <meta name="ClaudeBot" content="index" />
    <meta name="PerplexityBot" content="index" />
    <meta name="CCBot" content="index" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="climabr.app" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- PWA / theme -->
    <meta name="theme-color" content="#0f172a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 antialiased">
    <header class="border-b border-slate-800 px-4 py-3">
      <a href="/" class="text-lg font-bold tracking-tight text-white hover:text-slate-300">
        climabr<span class="text-emerald-400">.app</span>
      </a>
    </header>

    <main class="mx-auto max-w-3xl px-4 py-8">
      <slot />
    </main>

    <footer class="mt-16 border-t border-slate-800 px-4 py-6 text-center text-xs text-slate-500">
      Dados de fontes públicas: INMET, ANA, INPE, CETESB, SVS/MS, ANEEL &nbsp;·&nbsp;
      <a href="/llms.txt" class="underline hover:text-slate-300">llms.txt</a>
    </footer>
  </body>
</html>
