---
import type { DadosCidade } from '../lib/types';

interface Props {
  uv: DadosCidade['uv'];
}
const { uv } = Astro.props;

function corUV(indice: number): string {
  if (indice < 3) return 'text-emerald-400';
  if (indice < 6) return 'text-yellow-400';
  if (indice < 8) return 'text-orange-400';
  if (indice < 11) return 'text-red-400';
  return 'text-purple-400';
}

function barraUV(indice: number): string {
  if (indice < 3) return 'bg-emerald-500';
  if (indice < 6) return 'bg-yellow-500';
  if (indice < 8) return 'bg-orange-500';
  if (indice < 11) return 'bg-red-500';
  return 'bg-purple-600';
}

const pct = uv ? Math.min(100, Math.round((uv.indice / 12) * 100)) : 0;
---

{uv && uv.indice > 0 && (
  <section aria-label="Índice UV">
    <h2 class="mb-3 flex items-center gap-2 text-base font-semibold text-slate-200">
      <span aria-hidden="true">☀️</span> Índice UV
    </h2>
    <div class="rounded-lg border border-slate-800 bg-slate-900 p-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-slate-400" data-uv-categoria>{uv.categoria}</p>
          <p class={`text-3xl font-bold ${corUV(uv.indice)}`} data-uv-indice>
            {uv.indice.toFixed(1)}
          </p>
        </div>
        <div class="text-right text-xs text-slate-500">
          {uv.pico_inicio && uv.pico_fim && (
            <p>Pico: {uv.pico_inicio}–{uv.pico_fim}</p>
          )}
          <p class="mt-1">Fonte: {uv.fonte}</p>
        </div>
      </div>
      <div class="mt-3 h-2 w-full overflow-hidden rounded-full bg-slate-700">
        <div
          class={`h-full rounded-full transition-all ${barraUV(uv.indice)}`}
          style={`width: ${pct}%`}
          data-uv-barra
          role="progressbar"
          aria-label="Índice UV"
          aria-valuenow={uv.indice}
          aria-valuemin={0}
          aria-valuemax={12}
        />
      </div>
      <div class="mt-2 flex justify-between text-xs text-slate-600">
        <span>Baixo</span><span>Mod.</span><span>Alto</span><span>M.Alto</span><span>Extremo</span>
      </div>
    </div>
  </section>
)}
