---
interface Props {
  vento?: {
    velocidade_kmh: number | null;
    direcao_graus?: number | null;
    direcao?: string | null;
    max_kmh?: number | null;
    rajada_kmh?: number | null;
    direcao_dominante?: string | null;
    fonte: string;
  } | null;
}
const { vento } = Astro.props;

function corVento(kmh: number): string {
  if (kmh < 20) return 'text-emerald-400';
  if (kmh < 40) return 'text-yellow-400';
  if (kmh < 60) return 'text-orange-400';
  return 'text-red-400';
}

function labelVento(kmh: number): string {
  if (kmh < 6)  return 'Calmo';
  if (kmh < 20) return 'Fraco';
  if (kmh < 40) return 'Moderado';
  if (kmh < 60) return 'Forte';
  if (kmh < 90) return 'Muito forte';
  return 'Tempestade';
}

// Seta de direção: aponta de onde o vento VEM (180° invertido para visualização)
function setaDirecao(graus: number): string {
  const icones = ['↓','↙','←','↖','↑','↗','→','↘'];
  return icones[Math.round(graus / 45) % 8];
}

const vel = vento?.velocidade_kmh ?? vento?.max_kmh;
---

{vento && vel != null && (
  <section aria-label="Velocidade do vento">
    <h2 class="mb-3 flex items-center gap-2 text-base font-semibold text-slate-200">
      <span aria-hidden="true">🌬️</span> Vento
    </h2>
    <div class="rounded-lg border border-slate-800 bg-slate-900 p-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-slate-400">{labelVento(vel)}</p>
          <p class={`text-3xl font-bold ${corVento(vel)}`}>
            {vel} <span class="text-lg">km/h</span>
          </p>
          {vento.direcao && vento.direcao_graus != null && (
            <p class="text-sm text-slate-400 mt-1">
              {setaDirecao(vento.direcao_graus)} de {vento.direcao}
            </p>
          )}
        </div>
        <div class="text-right text-xs text-slate-500 space-y-1">
          {vento.max_kmh != null && vento.velocidade_kmh != null && (
            <p>Máx hoje: <span class="text-slate-300">{vento.max_kmh} km/h</span></p>
          )}
          {vento.rajada_kmh != null && (
            <p>Rajada: <span class="text-slate-300">{vento.rajada_kmh} km/h</span></p>
          )}
          {vento.direcao_dominante && (
            <p>Dom.: <span class="text-slate-300">{vento.direcao_dominante}</span></p>
          )}
          <p class="mt-1">{vento.fonte}</p>
        </div>
      </div>
    </div>
  </section>
)}
