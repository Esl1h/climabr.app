---
import type { DadosCidade } from '../lib/types';

interface Props {
  reservatorio: DadosCidade['reservatorio'];
}
const { reservatorio } = Astro.props;

function corNivel(pct: number): string {
  if (pct >= 70) return 'text-emerald-400';
  if (pct >= 40) return 'text-yellow-400';
  return 'text-red-400';
}
---

{reservatorio && (
  <section aria-label="Nível do reservatório">
    <h2 class="mb-3 flex items-center gap-2 text-base font-semibold text-slate-200">
      <span aria-hidden="true">🌊</span> Reservatório
    </h2>
    <div class="rounded-lg border border-slate-800 bg-slate-900 p-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-slate-400">{reservatorio.nome}</p>
          <p class={`text-3xl font-bold ${corNivel(reservatorio.nivel_pct)}`}>
            {reservatorio.nivel_pct.toFixed(1)}%
          </p>
        </div>
        <div class="text-right">
          {reservatorio.variacao_semana_pct > 0 ? (
            <span class="text-sm text-emerald-400">+{reservatorio.variacao_semana_pct.toFixed(1)}% semana</span>
          ) : reservatorio.variacao_semana_pct < 0 ? (
            <span class="text-sm text-red-400">{reservatorio.variacao_semana_pct.toFixed(1)}% semana</span>
          ) : (
            <span class="text-sm text-slate-400">estável</span>
          )}
          <p class="mt-1 text-xs text-slate-500">Fonte: {reservatorio.fonte}</p>
        </div>
      </div>
      <!-- Barra de progresso -->
      <div class="mt-3 h-2 w-full overflow-hidden rounded-full bg-slate-700">
        <div
          class={`h-full rounded-full transition-all ${
            reservatorio.nivel_pct >= 70
              ? 'bg-emerald-500'
              : reservatorio.nivel_pct >= 40
              ? 'bg-yellow-500'
              : 'bg-red-500'
          }`}
          style={`width: ${Math.min(100, reservatorio.nivel_pct)}%`}
          role="progressbar"
          aria-valuenow={reservatorio.nivel_pct}
          aria-valuemin={0}
          aria-valuemax={100}
        />
      </div>
    </div>
  </section>
)}
