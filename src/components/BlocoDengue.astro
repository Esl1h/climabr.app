---
import type { DadosCidade } from '../lib/types';

interface Props {
  dengue: DadosCidade['dengue'];
  chikungunya?: DadosCidade['dengue'];
  zika?: DadosCidade['dengue'];
}
const { dengue, chikungunya, zika } = Astro.props;

const CORES = [
  'text-emerald-400',
  'text-yellow-400',
  'text-orange-400',
  'text-red-400',
  'text-red-600',
];
const LABELS = ['Normal', 'Atenção', 'Alerta', 'Alerta Alto', 'Emergência'];
const ICONS = ['🟢', '🟡', '🟠', '🔴', '🚨'];

const doencas = [
  { label: 'Dengue', dados: dengue },
  { label: 'Chikungunya', dados: chikungunya },
  { label: 'Zika', dados: zika },
].filter(d => d.dados && d.dados.nivel_alerta != null);

const nivelMax = doencas.reduce((max, d) => Math.max(max, d.dados?.nivel_alerta ?? 0), 0);
const temAlerta = nivelMax >= 1;
---

{doencas.length > 0 && (
  <section aria-label="Alertas epidemiológicos">
    <h2 class="mb-3 flex items-center gap-2 text-base font-semibold text-slate-200">
      <span aria-hidden="true">🦟</span> Epidemiologia
    </h2>
    <div class="rounded-lg border border-slate-800 bg-slate-900 p-4 space-y-3">
      {doencas.map(({ label, dados }) => dados && (
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-slate-300">{label}</p>
            <p class={`text-lg font-bold ${CORES[dados.nivel_alerta ?? 0]}`}>
              {ICONS[dados.nivel_alerta ?? 0]} {LABELS[dados.nivel_alerta ?? 0]}
            </p>
          </div>
          <div class="text-right text-xs text-slate-500">
            <p>{(dados.casos_semana ?? 0).toLocaleString('pt-BR')} casos/semana</p>
            {dados.casos_estimados && dados.casos_estimados > dados.casos_semana && (
              <p>Est.: {dados.casos_estimados.toLocaleString('pt-BR')}</p>
            )}
          </div>
        </div>
      ))}
      <p class="text-xs text-slate-500 pt-1 border-t border-slate-800">
        Fonte: InfoDengue / Fiocruz / SVS
        {doencas[0]?.dados?.semana_epidemiologica && (
          <span> · SE {doencas[0].dados.semana_epidemiologica}</span>
        )}
      </p>
    </div>
  </section>
)}
