---
interface Props {
  ondas?: {
    altura_m: number | null;
    altura_max_m?: number | null;
    periodo_s: number | null;
    direcao?: string | null;
    swell_altura_m?: number | null;
    swell_periodo_s?: number | null;
    swell_direcao?: string | null;
    surf_nivel: string;
    surf_emoji: string;
    surf_descricao: string;
    fonte: string;
    atualizado_em?: string;
  } | null;
}
const { ondas } = Astro.props;

function corAltura(m: number): string {
  if (m < 0.4) return 'text-slate-400';
  if (m < 0.8) return 'text-blue-400';
  if (m < 2.5) return 'text-emerald-400';
  if (m < 4.0) return 'text-yellow-400';
  return 'text-red-400';
}

const SURF_COR: Record<string, string> = {
  bom:       'text-emerald-400 border-emerald-800 bg-emerald-950/30',
  razoavel:  'text-yellow-400 border-yellow-800 bg-yellow-950/20',
  ruim:      'text-red-400 border-red-800 bg-red-950/20',
  perigoso:  'text-red-500 border-red-700 bg-red-950/30',
  desconhecido: 'text-slate-400 border-slate-700 bg-slate-800/30',
};

const surfCor = SURF_COR[ondas?.surf_nivel ?? 'desconhecido'];
const altura = ondas?.altura_m ?? ondas?.altura_max_m;
---

{ondas && (
  <section aria-label="Ondas e condição para surf">
    <h2 class="mb-3 flex items-center gap-2 text-base font-semibold text-slate-200">
      <span aria-hidden="true">🏄</span> Ondas & Surf
    </h2>

    <!-- Farol de surf -->
    <div class={`rounded-lg border p-4 mb-3 ${surfCor}`}>
      <div class="flex items-center gap-3">
        <span class="text-3xl" aria-label={`Condição: ${ondas.surf_descricao}`}>
          {ondas.surf_emoji}
        </span>
        <div>
          <p class="font-semibold text-sm capitalize">{ondas.surf_descricao}</p>
          <p class="text-xs opacity-70">Condição para surf</p>
        </div>
      </div>
    </div>

    <!-- Dados das ondas -->
    <div class="rounded-lg border border-slate-800 bg-slate-900 p-4">
      <div class="grid grid-cols-2 gap-4">
        <!-- Altura -->
        <div>
          <p class="text-xs text-slate-500 mb-1">Altura atual</p>
          {altura != null ? (
            <p class={`text-2xl font-bold ${corAltura(altura)}`}>
              {altura.toFixed(1)}<span class="text-sm font-normal"> m</span>
            </p>
          ) : (
            <p class="text-slate-500 text-sm">N/D</p>
          )}
          {ondas.altura_max_m != null && ondas.altura_m != null && (
            <p class="text-xs text-slate-500">Máx hoje: {ondas.altura_max_m.toFixed(1)}m</p>
          )}
        </div>

        <!-- Período -->
        <div>
          <p class="text-xs text-slate-500 mb-1">Período</p>
          {ondas.periodo_s != null ? (
            <p class="text-2xl font-bold text-slate-200">
              {ondas.periodo_s.toFixed(0)}<span class="text-sm font-normal"> s</span>
            </p>
          ) : (
            <p class="text-slate-500 text-sm">N/D</p>
          )}
          {ondas.direcao && (
            <p class="text-xs text-slate-500">Dir.: {ondas.direcao}</p>
          )}
        </div>
      </div>

      <!-- Swell -->
      {(ondas.swell_altura_m != null || ondas.swell_periodo_s != null) && (
        <div class="mt-3 pt-3 border-t border-slate-800">
          <p class="text-xs text-slate-500 mb-2">Swell</p>
          <div class="flex gap-4 text-xs text-slate-400">
            {ondas.swell_altura_m != null && (
              <span><span class="text-slate-300">{ondas.swell_altura_m.toFixed(1)}m</span> altura</span>
            )}
            {ondas.swell_periodo_s != null && (
              <span><span class="text-slate-300">{ondas.swell_periodo_s.toFixed(0)}s</span> período</span>
            )}
            {ondas.swell_direcao && (
              <span>de <span class="text-slate-300">{ondas.swell_direcao}</span></span>
            )}
          </div>
        </div>
      )}

      <p class="mt-2 text-xs text-slate-600">{ondas.fonte}</p>
    </div>
  </section>
)}
