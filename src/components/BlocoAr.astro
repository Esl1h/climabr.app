---
import type { DadosCidade } from '../lib/types';

interface Props {
  qualidade_ar: DadosCidade['qualidade_ar'];
  umidade_pct?: number | null;
  pressao_hpa?: number | null;
  ponto_orvalho_c?: number | null;
}
const { qualidade_ar, umidade_pct, pressao_hpa, ponto_orvalho_c } = Astro.props;

function corAqi(indice: number): string {
  if (indice <= 50) return 'text-emerald-400';
  if (indice <= 100) return 'text-yellow-400';
  if (indice <= 150) return 'text-orange-400';
  if (indice <= 200) return 'text-red-400';
  return 'text-red-600';
}

function barraAqi(indice: number): string {
  if (indice <= 50) return 'bg-emerald-500';
  if (indice <= 100) return 'bg-yellow-500';
  if (indice <= 150) return 'bg-orange-500';
  if (indice <= 200) return 'bg-red-500';
  return 'bg-red-700';
}

const pct = qualidade_ar ? Math.min(100, Math.round((qualidade_ar.indice / 300) * 100)) : 0;
---

{qualidade_ar && (
  <section aria-label="Qualidade do ar">
    <h2 class="mb-3 flex items-center gap-2 text-base font-semibold text-slate-200">
      <span aria-hidden="true">💨</span> Qualidade do Ar
    </h2>
    <div class="rounded-lg border border-slate-800 bg-slate-900 p-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-slate-400" data-ar-categoria>{qualidade_ar.categoria}</p>
          <p class={`text-3xl font-bold ${corAqi(qualidade_ar.indice)}`} data-ar-indice>
            AQI {qualidade_ar.indice}
          </p>
          <p class="text-xs text-slate-500 mt-1">
            Principal: {qualidade_ar.principal_poluente}<span data-ar-pm25>{qualidade_ar.pm25 != null ? ` · PM2.5: ${qualidade_ar.pm25} µg/m³` : ''}</span>
          </p>
        </div>
        <div class="text-right text-xs text-slate-500">
          {qualidade_ar.pm10 != null && <p>PM10: {qualidade_ar.pm10} µg/m³</p>}
          {qualidade_ar.no2 != null && <p>NO₂: {qualidade_ar.no2} µg/m³</p>}
          <p class="mt-1">Fonte: {qualidade_ar.fonte}</p>
        </div>
      </div>
      <div class="mt-3 h-2 w-full overflow-hidden rounded-full bg-slate-700">
        <div
          class={`h-full rounded-full transition-all ${barraAqi(qualidade_ar.indice)}`}
          style={`width: ${pct}%`}
          data-ar-barra
          role="progressbar"
          aria-label="Qualidade do ar (AQI)"
          aria-valuenow={qualidade_ar.indice}
          aria-valuemin={0}
          aria-valuemax={300}
        />
      </div>
      <div class="mt-2 flex justify-between text-xs text-slate-600">
        <span>Boa</span><span>Moderada</span><span>Ruim</span><span>Péssima</span>
      </div>

      <div class="mt-3 grid grid-cols-3 gap-2 border-t border-slate-800 pt-3 text-center" data-condicoes>
        <div>
          <p class="text-xs text-slate-500">Umidade</p>
          <p class="text-sm font-semibold text-slate-200" data-cond="umidade">{umidade_pct != null ? `${umidade_pct}%` : '—'}</p>
        </div>
        <div>
          <p class="text-xs text-slate-500">Pressão</p>
          <p class="text-sm font-semibold text-slate-200" data-cond="pressao">{pressao_hpa != null ? `${pressao_hpa} hPa` : '—'}</p>
        </div>
        <div>
          <p class="text-xs text-slate-500">Ponto de orvalho</p>
          <p class="text-sm font-semibold text-slate-200" data-cond="orvalho">{ponto_orvalho_c != null ? `${ponto_orvalho_c}°C` : '—'}</p>
        </div>
      </div>
    </div>
  </section>
)}
